'use client';

import { PageTemplate } from '@/components/page-template';
import { SummaryCard } from '@/components/summary-card';
import { useState, useEffect } from 'react';
import { 
  getDashboard, 
  getQueueRanking, 
  getErrorRanking, 
  getReviewerRanking,
  type DashboardResponse,
  type QueueRankingResponse,
  type ErrorRankingResponse,
  type ReviewerRankingResponse
} from '@/lib/monitor-api';

/**
 * 🎯 实时数据监控页面
 * 
 * 核心目标：
 * 1. 快速发现数据异常（正确率突降、错误类型激增、队列异常）
 * 2. 实时监控关键指标（当日/昨日对比）
 * 3. 聚焦高风险问题（误判/漏判/申诉率）
 * 4. 支持快速下钻（点击跳转详情查询）
 */
export default function RealTimeMonitorPage() {
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  
  // API数据状态
  const [dashboardData, setDashboardData] = useState<DashboardResponse | null>(null);
  const [queueData, setQueueData] = useState<QueueRankingResponse | null>(null);
  const [errorData, setErrorData] = useState<ErrorRankingResponse | null>(null);
  const [reviewerData, setReviewerData] = useState<ReviewerRankingResponse | null>(null);
  
  // 日期状态（默认为昨天，因为今天数据可能还没准备好）
  const [selectedDate, setSelectedDate] = useState(() => {
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    return yesterday.toISOString().split('T')[0];
  });

  useEffect(() => {
    loadData();
  }, [selectedDate]);

  async function loadData() {
    setLoading(true);
    setError(null);
    
    try {
      // 并行请求所有API
      const [dashboard, queues, errors, reviewers] = await Promise.all([
        getDashboard(selectedDate),
        getQueueRanking(selectedDate, 90, 10),
        getErrorRanking(selectedDate, 10),
        getReviewerRanking(selectedDate, 85, 10)
      ]);
      
      setDashboardData(dashboard);
      setQueueData(queues);
      setErrorData(errors);
      setReviewerData(reviewers);
    } catch (err) {
      console.error('加载数据失败:', err);
      setError(err instanceof Error ? err.message : '未知错误');
    } finally {
      setLoading(false);
    }
  }

  if (loading) {
    return (
      <PageTemplate title="实时数据监控" subtitle="加载中...">
        <div className="panel">
          <p style={{ textAlign: 'center', padding: 'var(--spacing-xl)', color: 'var(--text-muted)' }}>
            正在加载数据...
          </p>
        </div>
      </PageTemplate>
    );
  }

  if (error || !dashboardData) {
    return (
      <PageTemplate title="实时数据监控" subtitle="加载失败">
        <div className="panel" style={{ background: 'var(--danger-bg)', borderColor: 'var(--danger)' }}>
          <p style={{ color: 'var(--danger)' }}>加载数据失败: {error || '数据为空'}</p>
          <button 
            onClick={loadData} 
            className="button"
            style={{ marginTop: 'var(--spacing-md)' }}
          >
            重试
          </button>
        </div>
      </PageTemplate>
    );
  }

  // 解构数据
  const { today, yesterday, changes, alerts } = dashboardData;
  
  // 判断异常状态
  const isCorrectRateAbnormal = changes.correct_rate < -5;
  const isMisjudgeAbnormal = changes.misjudge_rate > 2;
  const isAppealAbnormal = changes.appeal_rate > 3;

  return (
    <PageTemplate
      title="实时数据监控"
      subtitle={`${selectedDate} 实时数据 vs 昨日对比`}
    >
      {/* 日期选择器 */}
      <div className="panel">
        <label htmlFor="date-picker" style={{ marginRight: 'var(--spacing-sm)' }}>
          选择日期：
        </label>
        <input
          id="date-picker"
          type="date"
          value={selectedDate}
          onChange={(e) => setSelectedDate(e.target.value)}
          max={new Date().toISOString().split('T')[0]}
          style={{
            padding: 'var(--spacing-sm)',
            borderRadius: 'var(--radius)',
            border: '1px solid var(--border)'
          }}
        />
        <button
          onClick={loadData}
          className="button"
          style={{ marginLeft: 'var(--spacing-sm)' }}
        >
          刷新
        </button>
      </div>

      {/* 异常告警 */}
      {alerts && alerts.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)', background: 'var(--danger-bg)', borderColor: 'var(--danger)' }}>
          <h3 className="panel-title" style={{ color: 'var(--danger)' }}>🚨 异常告警</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            {alerts.map((alert, index) => (
              <div 
                key={index}
                style={{ 
                  padding: 'var(--spacing-sm)', 
                  marginBottom: index < alerts.length - 1 ? 'var(--spacing-xs)' : 0, 
                  background: 'white', 
                  borderRadius: 'var(--radius)', 
                  borderLeft: `3px solid var(--${alert.level})` 
                }}
              >
                <strong style={{ color: `var(--${alert.level})` }}>
                  {alert.level === 'critical' && '🚨 '}
                  {alert.level === 'error' && '❌ '}
                  {alert.level === 'warning' && '⚠️ '}
                  {alert.level === 'info' && 'ℹ️ '}
                  {alert.title}
                </strong>
                <p style={{ margin: '4px 0 0 0', fontSize: '0.875em', color: 'var(--text-muted)' }}>
                  {alert.message}
                </p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* 核心指标对比 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
        <h3 className="panel-title">📊 核心指标（当日 vs 昨日）</h3>
        
        <div className="grid-4" style={{ marginTop: 'var(--spacing-lg)' }}>
          <SummaryCard
            label="正确率"
            value={`${today.correct_rate.toFixed(2)}%`}
            hint={`昨日: ${yesterday.correct_rate.toFixed(2)}% ${changes.correct_rate >= 0 ? '↑' : '↓'} ${Math.abs(changes.correct_rate).toFixed(2)}%`}
            tone={isCorrectRateAbnormal ? 'danger' : (changes.correct_rate >= 0 ? 'success' : 'warning')}
          />

          <SummaryCard
            label="质检总量"
            value={today.total_qa.toLocaleString()}
            hint={`昨日: ${yesterday.total_qa.toLocaleString()} ${changes.total_qa >= 0 ? '↑' : '↓'} ${Math.abs(changes.total_qa).toLocaleString()}`}
            tone={Math.abs(changes.total_qa) > yesterday.total_qa * 0.2 ? 'warning' : 'neutral'}
          />

          <SummaryCard
            label="误判率"
            value={`${today.misjudge_rate.toFixed(2)}%`}
            hint={`昨日: ${yesterday.misjudge_rate.toFixed(2)}% ${changes.misjudge_rate >= 0 ? '↑' : '↓'} ${Math.abs(changes.misjudge_rate).toFixed(2)}%`}
            tone={isMisjudgeAbnormal ? 'danger' : (changes.misjudge_rate <= 0 ? 'success' : 'warning')}
          />

          <SummaryCard
            label="漏判率"
            value={`${today.miss_rate.toFixed(2)}%`}
            hint={`昨日: ${yesterday.miss_rate.toFixed(2)}% ${changes.miss_rate >= 0 ? '↑' : '↓'} ${Math.abs(changes.miss_rate).toFixed(2)}%`}
            tone={changes.miss_rate <= 0 ? 'success' : 'warning'}
          />
        </div>
      </div>

      {/* 队列质量排行 */}
      {queueData && queueData.queues.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">⚠️ 重点关注队列（正确率 &lt;90%）</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              {queueData.summary.message}
            </p>
            
            <div style={{ overflowX: 'auto' }}>
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead>
                  <tr style={{ background: 'var(--card-bg)', borderBottom: '2px solid var(--border)' }}>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>排名</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>队列名称</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>正确率</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>质检量</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>误判数</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>漏判数</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>主要错误</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>操作</th>
                  </tr>
                </thead>
                <tbody>
                  {queueData.queues.map((queue) => (
                    <tr key={queue.queue_name} style={{ borderBottom: '1px solid var(--border)' }}>
                      <td style={{ padding: 'var(--spacing-sm)' }}>{queue.rank}</td>
                      <td style={{ padding: 'var(--spacing-sm)', fontWeight: 600 }}>{queue.queue_name}</td>
                      <td style={{ 
                        padding: 'var(--spacing-sm)', 
                        textAlign: 'right', 
                        color: queue.correct_rate < 85 ? 'var(--danger)' : 'var(--warning)', 
                        fontWeight: 600 
                      }}>
                        {queue.correct_rate.toFixed(2)}%
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>{queue.total_qa.toLocaleString()}</td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>{queue.misjudge_count}</td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>{queue.miss_count}</td>
                      <td style={{ padding: 'var(--spacing-sm)' }}>{queue.top_errors.slice(0, 3).join(', ')}</td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>
                        <a 
                          href={`/details?queue_name=${encodeURIComponent(queue.queue_name)}`} 
                          style={{ color: 'var(--primary)', textDecoration: 'none' }}
                        >
                          详情 →
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* 错误类型分布 */}
      {errorData && errorData.error_types.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">🎯 高频错误类型（Top 5）</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              聚焦高频错误，精准培训提升 | Top 5覆盖率：{errorData.summary.top5_coverage.toFixed(1)}%
            </p>
            
            <div className="grid-2" style={{ gap: 'var(--spacing-md)' }}>
              {errorData.error_types.slice(0, 5).map((error, index) => {
                const color = index === 0 ? 'danger' : (index === 1 ? 'warning' : 'info');
                return (
                  <div 
                    key={error.error_type}
                    style={{ 
                      padding: 'var(--spacing-md)', 
                      background: 'var(--card-bg)', 
                      borderRadius: 'var(--radius)', 
                      borderLeft: `3px solid var(--${color})` 
                    }}
                  >
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '8px' }}>
                      <strong>{error.error_type}</strong>
                      <span style={{ color: `var(--${color})`, fontWeight: 700, fontSize: '1.25em' }}>
                        {error.count} 次
                      </span>
                    </div>
                    <div style={{ fontSize: '0.875em', color: 'var(--text-muted)', marginBottom: '8px' }}>
                      占比: {error.rate.toFixed(1)}% | 误判: {error.misjudge_count} | 漏判: {error.miss_count}
                    </div>
                    <div style={{ marginTop: '8px' }}>
                      <a 
                        href={`/details?error_type=${encodeURIComponent(error.error_type)}`} 
                        style={{ color: 'var(--primary)', fontSize: '0.875em', textDecoration: 'none' }}
                      >
                        查看明细 →
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* 审核人员表现 */}
      {reviewerData && reviewerData.reviewers.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">👤 重点关注审核人（正确率 &lt;85%）</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              共 {reviewerData.summary.total_below_threshold} 人需要加强培训 | 平均正确率：{reviewerData.summary.avg_correct_rate.toFixed(2)}%
            </p>
            
            <div style={{ overflowX: 'auto' }}>
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead>
                  <tr style={{ background: 'var(--card-bg)', borderBottom: '2px solid var(--border)' }}>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>排名</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>审核人</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>正确率</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>审核量</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>主要问题</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>所属队列</th>
                    {reviewerData.reviewers.some(r => r.group_name) && (
                      <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>批次</th>
                    )}
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>操作</th>
                  </tr>
                </thead>
                <tbody>
                  {reviewerData.reviewers.map((reviewer) => (
                    <tr key={reviewer.reviewer_id} style={{ borderBottom: '1px solid var(--border)' }}>
                      <td style={{ padding: 'var(--spacing-sm)' }}>{reviewer.rank}</td>
                      <td style={{ padding: 'var(--spacing-sm)', fontWeight: 600 }}>{reviewer.reviewer_name}</td>
                      <td style={{ 
                        padding: 'var(--spacing-sm)', 
                        textAlign: 'right', 
                        color: reviewer.correct_rate < 80 ? 'var(--danger)' : 'var(--warning)', 
                        fontWeight: 600 
                      }}>
                        {reviewer.correct_rate.toFixed(2)}%
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>{reviewer.total_qa}</td>
                      <td style={{ padding: 'var(--spacing-sm)' }}>{reviewer.main_errors.slice(0, 2).join(', ')}</td>
                      <td style={{ padding: 'var(--spacing-sm)' }}>{reviewer.queue_name}</td>
                      {reviewerData.reviewers.some(r => r.group_name) && (
                        <td style={{ padding: 'var(--spacing-sm)' }}>{reviewer.group_name || '-'}</td>
                      )}
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>
                        <a 
                          href={`/details?reviewer_name=${encodeURIComponent(reviewer.reviewer_name)}`} 
                          style={{ color: 'var(--primary)', textDecoration: 'none' }}
                        >
                          详情 →
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* 快速操作 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
        <h3 className="panel-title">⚡ 快速操作</h3>
        
        <div style={{ marginTop: 'var(--spacing-md)', display: 'flex', gap: 'var(--spacing-sm)', flexWrap: 'wrap' }}>
          <a href="/details" className="button button-primary" style={{ textDecoration: 'none' }}>
            📋 查看全部明细
          </a>
          <a href={`/details?start_date=${selectedDate}&end_date=${selectedDate}`} className="button" style={{ textDecoration: 'none' }}>
            📅 导出当日数据
          </a>
          <a href="/internal" className="button" style={{ textDecoration: 'none' }}>
            📊 内检看板
          </a>
          <a href="/newcomers" className="button" style={{ textDecoration: 'none' }}>
            👤 新人追踪
          </a>
        </div>
      </div>

      {/* 使用说明 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)', background: 'var(--info-bg)', borderColor: 'var(--info)' }}>
        <h3 className="panel-title" style={{ color: 'var(--info)' }}>💡 监控说明</h3>
        
        <ul style={{ marginLeft: 'var(--spacing-lg)', marginTop: 'var(--spacing-md)', lineHeight: 2 }}>
          <li><strong>异常告警</strong>：自动检测正确率/误判率/漏判率异常波动</li>
          <li><strong>队列排行</strong>：聚焦正确率 &lt;90% 的队列，优先改进</li>
          <li><strong>错误类型</strong>：统计高频错误，精准培训提升</li>
          <li><strong>人员表现</strong>：识别正确率 &lt;85% 的审核人，加强培训</li>
          <li><strong>快速下钻</strong>：点击「详情 →」跳转到明细查询页面</li>
          <li><strong>数据来源</strong>：通过API实时获取真实数据</li>
        </ul>
      </div>
    </PageTemplate>
  );
}
