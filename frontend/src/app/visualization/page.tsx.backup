'use client';

import { PageTemplate } from '@/components/page-template';
import { SummaryCard } from '@/components/summary-card';
import { useState, useEffect } from 'react';
import {
  getPerformanceTrend,
  getApiPerformance,
  getQueueDistribution,
  getErrorTrend,
  type PerformanceTrendResponse,
  type ApiPerformanceResponse,
  type QueueDistributionResponse,
  type ErrorTrendResponse
} from '@/lib/visualization-api';

/**
 * 📊 数据可视化页面
 * 
 * 核心目标：
 * 1. 性能趋势分析（正确率/误判率/漏判率变化）
 * 2. API性能监控（接口响应时间）
 * 3. 队列分布分析（工作量分布）
 * 4. 错误趋势预测（高频错误变化）
 */
export default function DataVisualizationPage() {
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  
  // API数据状态
  const [performanceData, setPerformanceData] = useState<PerformanceTrendResponse | null>(null);
  const [apiPerfData, setApiPerfData] = useState<ApiPerformanceResponse | null>(null);
  const [queueData, setQueueData] = useState<QueueDistributionResponse | null>(null);
  const [errorTrendData, setErrorTrendData] = useState<ErrorTrendResponse | null>(null);
  
  // 日期范围
  const [days, setDays] = useState(7);

  useEffect(() => {
    loadData();
  }, [days]);

  async function loadData() {
    setLoading(true);
    setError(null);
    
    try {
      // 计算日期范围
      const endDate = new Date();
      endDate.setDate(endDate.getDate() - 1); // 昨天
      const startDate = new Date(endDate);
      startDate.setDate(startDate.getDate() - days + 1);
      
      const startDateStr = startDate.toISOString().split('T')[0];
      const endDateStr = endDate.toISOString().split('T')[0];
      
      // 并行请求所有API
      const [performance, apiPerf, queue, errorTrend] = await Promise.all([
        getPerformanceTrend(startDateStr, endDateStr),
        getApiPerformance(startDateStr, endDateStr),
        getQueueDistribution(endDateStr),
        getErrorTrend(startDateStr, endDateStr, 5)
      ]);
      
      setPerformanceData(performance);
      setApiPerfData(apiPerf);
      setQueueData(queue);
      setErrorTrendData(errorTrend);
    } catch (err) {
      console.error('加载数据失败:', err);
      setError(err instanceof Error ? err.message : '未知错误');
    } finally {
      setLoading(false);
    }
  }

  if (loading) {
    return (
      <PageTemplate title="数据可视化" subtitle="加载中...">
        <div className="panel">
          <p style={{ textAlign: 'center', padding: 'var(--spacing-xl)', color: 'var(--text-muted)' }}>
            正在加载数据...
          </p>
        </div>
      </PageTemplate>
    );
  }

  if (error || !performanceData) {
    return (
      <PageTemplate title="数据可视化" subtitle="加载失败">
        <div className="panel" style={{ background: 'var(--danger-bg)', borderColor: 'var(--danger)' }}>
          <p style={{ color: 'var(--danger)' }}>加载数据失败: {error || '数据为空'}</p>
          <button 
            onClick={loadData} 
            className="button"
            style={{ marginTop: 'var(--spacing-md)' }}
          >
            重试
          </button>
        </div>
      </PageTemplate>
    );
  }

  return (
    <PageTemplate
      title="数据可视化"
      subtitle="多维度数据趋势与分布分析"
    >
      {/* 时间范围选择 */}
      <div className="panel">
        <label htmlFor="days-picker" style={{ marginRight: 'var(--spacing-sm)' }}>
          时间范围：
        </label>
        <select
          id="days-picker"
          value={days}
          onChange={(e) => setDays(Number(e.target.value))}
          style={{
            padding: 'var(--spacing-sm)',
            borderRadius: 'var(--radius)',
            border: '1px solid var(--border)'
          }}
        >
          <option value={7}>最近7天</option>
          <option value={14}>最近14天</option>
          <option value={30}>最近30天</option>
        </select>
        <button
          onClick={loadData}
          className="button"
          style={{ marginLeft: 'var(--spacing-sm)' }}
        >
          刷新
        </button>
      </div>

      {/* 性能趋势总览 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
        <h3 className="panel-title">📈 性能趋势总览</h3>
        
        <div className="grid-4" style={{ marginTop: 'var(--spacing-lg)' }}>
          <SummaryCard
            label="平均正确率"
            value={`${performanceData.summary.avg_correct_rate.toFixed(2)}%`}
            hint={`趋势: ${performanceData.summary.trend_direction === 'up' ? '↑ 上升' : (performanceData.summary.trend_direction === 'down' ? '↓ 下降' : '→ 稳定')}`}
            tone={performanceData.summary.trend_direction === 'up' ? 'success' : (performanceData.summary.trend_direction === 'down' ? 'danger' : 'neutral')}
          />

          <SummaryCard
            label="最佳表现"
            value={performanceData.summary.best_date}
            hint={`正确率最高的一天`}
            tone="success"
          />

          <SummaryCard
            label="最差表现"
            value={performanceData.summary.worst_date}
            hint={`正确率最低的一天`}
            tone="danger"
          />

          <SummaryCard
            label="日均审核量"
            value={Math.round(
              performanceData.review_counts.reduce((a, b) => a + b, 0) / performanceData.review_counts.length
            ).toLocaleString()}
            hint={`总计: ${performanceData.review_counts.reduce((a, b) => a + b, 0).toLocaleString()}`}
            tone="neutral"
          />
        </div>
      </div>

      {/* 性能趋势图表 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
        <h3 className="panel-title">📊 正确率趋势</h3>
        
        <div style={{ marginTop: 'var(--spacing-md)', overflowX: 'auto' }}>
          <table style={{ width: '100%', borderCollapse: 'collapse' }}>
            <thead>
              <tr style={{ background: 'var(--card-bg)', borderBottom: '2px solid var(--border)' }}>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>日期</th>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>正确率</th>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>误判率</th>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>漏判率</th>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>申诉率</th>
                <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>审核量</th>
              </tr>
            </thead>
            <tbody>
              {performanceData.dates.map((date, index) => (
                <tr key={date} style={{ borderBottom: '1px solid var(--border)' }}>
                  <td style={{ padding: 'var(--spacing-sm)' }}>{date}</td>
                  <td style={{ 
                    padding: 'var(--spacing-sm)', 
                    textAlign: 'right',
                    color: performanceData.correct_rates[index] >= 90 ? 'var(--success)' : 'var(--danger)',
                    fontWeight: 600
                  }}>
                    {performanceData.correct_rates[index].toFixed(2)}%
                  </td>
                  <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                    {performanceData.misjudge_rates[index].toFixed(2)}%
                  </td>
                  <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                    {performanceData.miss_rates[index].toFixed(2)}%
                  </td>
                  <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                    {performanceData.appeal_rates[index].toFixed(2)}%
                  </td>
                  <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                    {performanceData.review_counts[index].toLocaleString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* API性能监控 */}
      {apiPerfData && apiPerfData.endpoints && apiPerfData.endpoints.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">⚡ API性能监控</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              平均响应时间: {apiPerfData.summary.avg_response_time.toFixed(0)}ms | 
              慢接口数: {apiPerfData.summary.slow_endpoints}
            </p>
            
            <div style={{ overflowX: 'auto' }}>
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead>
                  <tr style={{ background: 'var(--card-bg)', borderBottom: '2px solid var(--border)' }}>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>接口</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>平均耗时</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>P50</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>P95</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>P99</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>调用次数</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>错误率</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>状态</th>
                  </tr>
                </thead>
                <tbody>
                  {apiPerfData.endpoints.map((endpoint) => (
                    <tr key={endpoint.endpoint} style={{ borderBottom: '1px solid var(--border)' }}>
                      <td style={{ padding: 'var(--spacing-sm)', fontFamily: 'monospace', fontSize: '0.875em' }}>
                        {endpoint.endpoint}
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.avg_response_time.toFixed(0)}ms
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.p50_response_time.toFixed(0)}ms
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.p95_response_time.toFixed(0)}ms
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.p99_response_time.toFixed(0)}ms
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.total_requests.toLocaleString()}
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {endpoint.error_rate.toFixed(2)}%
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'center' }}>
                        <span style={{
                          padding: '2px 8px',
                          borderRadius: 'var(--radius)',
                          fontSize: '0.75em',
                          fontWeight: 600,
                          background: 
                            endpoint.status === 'excellent' ? 'var(--success-bg)' :
                            endpoint.status === 'good' ? 'var(--info-bg)' :
                            endpoint.status === 'normal' ? 'var(--warning-bg)' :
                            'var(--danger-bg)',
                          color:
                            endpoint.status === 'excellent' ? 'var(--success)' :
                            endpoint.status === 'good' ? 'var(--info)' :
                            endpoint.status === 'normal' ? 'var(--warning)' :
                            'var(--danger)'
                        }}>
                          {endpoint.status === 'excellent' && '优秀'}
                          {endpoint.status === 'good' && '良好'}
                          {endpoint.status === 'normal' && '一般'}
                          {endpoint.status === 'slow' && '较慢'}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* 队列分布 */}
      {queueData && queueData.queues && queueData.queues.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">📊 队列工作量分布</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              总队列数: {queueData.summary.total_queues} | 
              总审核量: {queueData.summary.total_reviews.toLocaleString()} | 
              平均正确率: {queueData.summary.avg_correct_rate.toFixed(2)}%
            </p>
            
            <div style={{ overflowX: 'auto' }}>
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead>
                  <tr style={{ background: 'var(--card-bg)', borderBottom: '2px solid var(--border)' }}>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'left' }}>队列名称</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>审核量</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>占比</th>
                    <th style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>正确率</th>
                  </tr>
                </thead>
                <tbody>
                  {queueData.queues.map((queue) => (
                    <tr key={queue.queue_name} style={{ borderBottom: '1px solid var(--border)' }}>
                      <td style={{ padding: 'var(--spacing-sm)', fontWeight: 600 }}>{queue.queue_name}</td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {queue.review_count.toLocaleString()}
                      </td>
                      <td style={{ padding: 'var(--spacing-sm)', textAlign: 'right' }}>
                        {queue.percentage.toFixed(1)}%
                      </td>
                      <td style={{ 
                        padding: 'var(--spacing-sm)', 
                        textAlign: 'right',
                        color: queue.correct_rate >= 90 ? 'var(--success)' : 'var(--warning)',
                        fontWeight: 600
                      }}>
                        {queue.correct_rate.toFixed(2)}%
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* 错误趋势 */}
      {errorTrendData && errorTrendData.error_types && errorTrendData.error_types.length > 0 && (
        <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
          <h3 className="panel-title">📉 高频错误趋势（Top 5）</h3>
          
          <div style={{ marginTop: 'var(--spacing-md)' }}>
            <p style={{ color: 'var(--text-muted)', fontSize: '0.875em', marginBottom: 'var(--spacing-md)' }}>
              总错误数: {errorTrendData.summary.total_errors.toLocaleString()} | 
              日均错误: {errorTrendData.summary.avg_daily_errors.toFixed(0)} | 
              峰值: {errorTrendData.summary.peak_date} ({errorTrendData.summary.peak_count}次)
            </p>
            
            {errorTrendData.error_types.map((errorType, index) => (
              <div 
                key={errorType.error_type}
                style={{ 
                  marginBottom: 'var(--spacing-md)', 
                  padding: 'var(--spacing-md)', 
                  background: 'var(--card-bg)', 
                  borderRadius: 'var(--radius)',
                  borderLeft: `3px solid ${index === 0 ? 'var(--danger)' : (index === 1 ? 'var(--warning)' : 'var(--info)')}`
                }}
              >
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '8px' }}>
                  <strong>{errorType.error_type}</strong>
                  <div style={{ fontSize: '0.875em', color: 'var(--text-muted)' }}>
                    总计: {errorType.total_count} | 
                    日均: {errorType.avg_daily.toFixed(1)} | 
                    趋势: {
                      errorType.trend === 'increasing' ? '↑ 上升' :
                      errorType.trend === 'decreasing' ? '↓ 下降' :
                      '→ 稳定'
                    }
                  </div>
                </div>
                
                <div style={{ display: 'flex', gap: '4px', marginTop: '8px', height: '40px', alignItems: 'flex-end' }}>
                  {errorType.daily_counts.map((count, i) => {
                    const maxCount = Math.max(...errorType.daily_counts);
                    const height = maxCount > 0 ? (count / maxCount * 100) : 0;
                    return (
                      <div
                        key={i}
                        style={{
                          flex: 1,
                          height: `${height}%`,
                          background: index === 0 ? 'var(--danger)' : (index === 1 ? 'var(--warning)' : 'var(--info)'),
                          borderRadius: '2px 2px 0 0',
                          opacity: 0.8,
                          transition: 'all 0.3s'
                        }}
                        title={`${errorTrendData.dates[i]}: ${count}次`}
                      />
                    );
                  })}
                </div>
                
                <div style={{ display: 'flex', justifyContent: 'space-between', marginTop: '4px', fontSize: '0.75em', color: 'var(--text-muted)' }}>
                  <span>{errorTrendData.dates[0]}</span>
                  <span>{errorTrendData.dates[errorTrendData.dates.length - 1]}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* 快速操作 */}
      <div className="panel" style={{ marginTop: 'var(--spacing-lg)' }}>
        <h3 className="panel-title">⚡ 快速操作</h3>
        
        <div style={{ marginTop: 'var(--spacing-md)', display: 'flex', gap: 'var(--spacing-sm)', flexWrap: 'wrap' }}>
          <a href="/monitor" className="button button-primary" style={{ textDecoration: 'none' }}>
            📊 实时监控
          </a>
          <a href="/error-analysis" className="button" style={{ textDecoration: 'none' }}>
            🔍 错误分析
          </a>
          <a href="/details" className="button" style={{ textDecoration: 'none' }}>
            📋 明细查询
          </a>
        </div>
      </div>
    </PageTemplate>
  );
}
